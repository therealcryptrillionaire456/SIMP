# ═══════════════════════════════════════════════════════════════════════
# SECTION 8: PATTERNS TO FOLLOW
# ═══════════════════════════════════════════════════════════════════════

When creating new modules, follow these existing patterns:

DATACLASS PATTERN (see simp/compat/rollback.py):
  @dataclass
  class RecordName:
      field_a: str
      field_b: float
      timestamp: str  # ISO8601 UTC

THREAD-SAFE MANAGER PATTERN (see simp/compat/approval_queue.py):
  class ManagerName:
      def __init__(self):
          self._lock = threading.Lock()
          self._log_path = Path("data/something.jsonl")
      def _append_log(self, record: Dict) -> None:
          with self._lock:
              with open(self._log_path, "a") as f:
                  f.write(json.dumps(record) + "\n")

SINGLETON PATTERN (see simp/compat/ops_policy.py):
  MODULE_SINGLETON = ManagerName()

TEST PATTERN (see tests/test_financial_ops_connector.py):
  Use pytest fixtures with TemporaryDirectory for file-based tests
  Use StubExchangeConnector / StubPaymentConnector for mocking
  Use python3.10 -m pytest (not python3)

ABC PATTERN (see simp/compat/payment_connector.py):
  from abc import ABC, abstractmethod
  class ConnectorABC(ABC):
      @abstractmethod
      def method(self) -> ReturnType: ...
  class StubConnector(ConnectorABC):
      # Concrete implementation for testing

