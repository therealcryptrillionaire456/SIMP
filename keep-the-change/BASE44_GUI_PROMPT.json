{
  "project_name": "KeepTheChange.com Dynamic GUI",
  "project_description": "AI-powered shopping assistant that automatically finds cheapest grocery prices, purchases items, arranges express shipping, and reinvests savings into cryptocurrency markets. Users can tip agents and subscribe to investment tiers for a share of crypto returns.",
  
  "backend_architecture": {
    "framework": "FastAPI with SQLAlchemy (async)",
    "database": "PostgreSQL",
    "authentication": "JWT tokens with OAuth2",
    "file_structure": {
      "api_routers": [
        "shopping.py",
        "crypto.py", 
        "subscriptions.py",
        "users.py",
        "payments.py",
        "admin.py",
        "mobile.py"
      ],
      "schemas": [
        "shopping.py",
        "crypto.py",
        "user.py",
        "subscription.py", 
        "payment.py",
        "admin.py"
      ]
    }
  },
  
  "api_endpoints": {
    "authentication": {
      "POST /api/auth/login": "User login with email/password",
      "POST /api/auth/register": "User registration",
      "POST /api/auth/refresh": "Refresh JWT token",
      "POST /api/auth/logout": "User logout",
      "POST /api/auth/forgot-password": "Password reset request",
      "POST /api/auth/reset-password": "Password reset confirmation"
    },
    
    "user_management": {
      "GET /api/users/me": "Get current user profile",
      "PUT /api/users/me": "Update user profile",
      "GET /api/users/me/preferences": "Get user preferences",
      "PUT /api/users/me/preferences": "Update user preferences",
      "GET /api/users/me/notifications": "Get user notifications",
      "PUT /api/users/me/notifications/{notification_id}/read": "Mark notification as read",
      "DELETE /api/users/me": "Delete user account"
    },
    
    "shopping": {
      "POST /api/shopping/receipts/scan": "Scan receipt image/text",
      "GET /api/shopping/receipts": "List user receipts",
      "GET /api/shopping/receipts/{receipt_id}": "Get receipt details",
      "POST /api/shopping/optimize": "Optimize shopping list for price",
      "POST /api/shopping/purchase": "Make purchase with optimized items",
      "GET /api/shopping/purchases": "List user purchases",
      "GET /api/shopping/purchases/{purchase_id}": "Get purchase details",
      "POST /api/shopping/barcode/scan": "Scan barcode for product info",
      "GET /api/shopping/retailers": "List supported retailers",
      "GET /api/shopping/products/search": "Search products across retailers",
      "GET /api/shopping/products/{product_id}": "Get product details"
    },
    
    "crypto_investment": {
      "GET /api/crypto/portfolio": "Get user crypto portfolio",
      "GET /api/crypto/transactions": "List crypto transactions",
      "GET /api/crypto/transactions/{transaction_id}": "Get transaction details",
      "POST /api/crypto/invest": "Invest savings into crypto",
      "POST /api/crypto/withdraw": "Withdraw from crypto portfolio",
      "GET /api/crypto/market-data": "Get current crypto market data",
      "GET /api/crypto/historical/{symbol}": "Get historical price data",
      "GET /api/crypto/performance": "Get portfolio performance metrics",
      "GET /api/crypto/allocations": "Get current allocation strategy",
      "PUT /api/crypto/allocations": "Update allocation strategy"
    },
    
    "subscriptions": {
      "GET /api/subscriptions/plans": "List available subscription plans",
      "GET /api/subscriptions/current": "Get current subscription",
      "POST /api/subscriptions/subscribe": "Subscribe to a plan",
      "POST /api/subscriptions/cancel": "Cancel subscription",
      "POST /api/subscriptions/upgrade": "Upgrade subscription tier",
      "GET /api/subscriptions/invoices": "List subscription invoices",
      "GET /api/subscriptions/invoices/{invoice_id}": "Get invoice details",
      "POST /api/subscriptions/promo-code": "Apply promo code",
      "GET /api/subscriptions/trial-status": "Check trial status"
    },
    
    "payments": {
      "GET /api/payments/methods": "List payment methods",
      "POST /api/payments/methods": "Add payment method",
      "DELETE /api/payments/methods/{method_id}": "Remove payment method",
      "POST /api/payments/tip": "Tip agent",
      "GET /api/payments/transactions": "List payment transactions",
      "GET /api/payments/balance": "Get user balance",
      "POST /api/payments/deposit": "Deposit funds",
      "POST /api/payments/withdraw": "Withdraw funds"
    },
    
    "admin": {
      "GET /api/admin/users": "List all users (admin only)",
      "GET /api/admin/users/{user_id}": "Get user details (admin only)",
      "PUT /api/admin/users/{user_id}": "Update user (admin only)",
      "GET /api/admin/transactions": "List all transactions (admin only)",
      "GET /api/admin/financial-report": "Generate financial report (admin only)",
      "GET /api/admin/system-metrics": "Get system metrics (admin only)",
      "GET /api/admin/audit-logs": "Get audit logs (admin only)",
      "POST /api/admin/broadcast": "Send broadcast notification (admin only)"
    }
  },
  
  "data_models": {
    "User": {
      "id": "UUID",
      "email": "string",
      "first_name": "string",
      "last_name": "string",
      "phone": "string (optional)",
      "avatar_url": "string (optional)",
      "preferences": "JSON object",
      "created_at": "datetime",
      "updated_at": "datetime",
      "email_verified": "boolean",
      "phone_verified": "boolean",
      "status": "string (active, suspended, deleted)"
    },
    
    "Receipt": {
      "id": "UUID",
      "user_id": "UUID",
      "retailer": "string",
      "total_amount": "decimal",
      "tax_amount": "decimal",
      "items": "JSON array of items",
      "scan_method": "string (image, text, manual)",
      "scan_confidence": "float",
      "scan_date": "datetime",
      "created_at": "datetime"
    },
    
    "Purchase": {
      "id": "UUID",
      "user_id": "UUID",
      "receipt_id": "UUID (optional)",
      "items": "JSON array of purchased items",
      "total_amount": "decimal",
      "savings_amount": "decimal",
      "status": "string (pending, processing, shipped, delivered, cancelled)",
      "tracking_number": "string (optional)",
      "estimated_delivery": "datetime (optional)",
      "actual_delivery": "datetime (optional)",
      "created_at": "datetime"
    },
    
    "CryptoPortfolio": {
      "user_id": "UUID",
      "total_value": "decimal",
      "available_balance": "decimal",
      "invested_balance": "decimal",
      "allocations": "JSON object of asset allocations",
      "daily_change": "decimal",
      "total_return": "decimal",
      "last_updated": "datetime"
    },
    
    "Subscription": {
      "id": "UUID",
      "user_id": "UUID",
      "plan_id": "string",
      "plan_name": "string",
      "status": "string (active, cancelled, expired, trial)",
      "current_period_start": "datetime",
      "current_period_end": "datetime",
      "cancel_at_period_end": "boolean",
      "created_at": "datetime",
      "updated_at": "datetime"
    }
  },
  
