      "id": 13,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "quantumarb_open_positions", "legendFormat": "{{venue}}", "refId": "A", "interval": "" }
