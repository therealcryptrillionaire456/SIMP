# =============================================================================
# COINBASE API CREDENTIALS TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual API credentials
# NEVER commit .env files to version control
#
# Usage:
#   source scripts/load_env.sh
#   python gate4_inbox_consumer.py --dry-run
#
# =============================================================================

# Coinbase API Key Name (organization-level key identifier)
# Format: organizations/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/apiKeys/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
COINBASE_API_KEY_NAME=organizations/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/apiKeys/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Coinbase API Private Key (EC PRIVATE KEY - HIGHLY SENSITIVE)
# Format: -----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----
COINBASE_API_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----
MHcCAQEEI...YOUR_PRIVATE_KEY_HERE...AwEHoUQDQgAE...
-----END EC PRIVATE KEY-----

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================
# Set to "sandbox" for testing, "production" for live trading
SIM_ENVIRONMENT=sandbox

# Enable debug mode for verbose logging
SIM_DEBUG_MODE=false

# Log level: DEBUG, INFO, WARNING, ERROR
SIM_LOG_LEVEL=INFO

# =============================================================================
# API SECURITY
# =============================================================================
# Rate limiting and security settings
COINBASE_RATE_LIMIT_PER_MINUTE=60
COINBASE_TIMEOUT_SECONDS=30
COINBASE_RETRY_ATTEMPTS=3

# =============================================================================
# MONITORING & ALERTING
# =============================================================================
# Enable monitoring and logging
ENABLE_MONITORING=true

# Webhook URL for alerts (optional)
ALERT_WEBHOOK_URL=

# Emergency stop button (set to true to disable all trading)
EMERGENCY_STOP=false