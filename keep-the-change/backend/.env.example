# KEEPTHECHANGE.com Backend Environment Variables
# Copy this file to .env and update the values

# Application
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-here-change-in-production
APP_NAME=KEEPTHECHANGE.com

# Server
HOST=127.0.0.1
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/keepthechange

# Redis
REDIS_URL=redis://localhost:6379/0

# SIMP Integration
SIMP_BROKER_URL=http://localhost:5555
SIMP_API_KEY=test_key
SIMP_INTEGRATION_ENABLED=true

# Payment Processing (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Crypto Trading
CRYPTO_TRADING_ENABLED=true
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Solana Integration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WALLET_PRIVATE_KEY=your_solana_wallet_private_key

# Retailer APIs
WALMART_API_KEY=your_walmart_api_key
TARGET_API_KEY=your_target_api_key
AMAZON_ASSOCIATE_TAG=your_amazon_associate_tag

# Shipping APIs
SHIPENGINE_API_KEY=your_shipengine_api_key
EASYPOST_API_KEY=your_easypost_api_key

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@keepthechange.com

# Social Authentication
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
APPLE_PRIVATE_KEY=your_apple_private_key

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# File Uploads
MAX_UPLOAD_SIZE=16777216  # 16MB
UPLOAD_DIR=uploads

# Analytics
MIXPANEL_TOKEN=your_mixpanel_token
SEGMENT_WRITE_KEY=your_segment_write_key

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Business Logic
MIN_SAVINGS_FOR_INVESTMENT=0.01
MAX_INVESTMENT_PER_DAY=100.00
DEFAULT_CRYPTO_ASSET=SOL
PLATFORM_FEE_PERCENTAGE=0.20