# SECTION 10: COMMON COMMANDS
# ═══════════════════════════════════════════════════════════════════════

Compile check:  python3.10 -m py_compile <file.py>
Run one test:   python3.10 -m pytest tests/<test_file>.py -v
Run all tests:  SIMP_REQUIRE_API_KEY=false python3.10 -m pytest tests/ -v --tb=short
Check broker:   curl -s http://127.0.0.1:5555/health
Check agents:   curl -s http://127.0.0.1:5555/agents
Check stats:    curl -s http://127.0.0.1:5555/stats
Route intent:   curl -X POST http://127.0.0.1:5555/intents/route -H "Content-Type: application/json" -H "X-API-Key: $SIMP_API_KEY" -d '{"intent_type":"ping","source_agent":"goose","target_agent":"auto"}'
)
