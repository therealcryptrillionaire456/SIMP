  "description": "QuantumArb Trading System — Unified Observability Dashboard (T31)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Decision Engine",
      "type": "row"
    },
    {
      "title": "Decision Rate (go / no_go / review per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(quantumarb_decisions_total[1m])) by (decision)",
          "legendFormat": "{{decision}}",
          "refId": "A",
          "interval": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "color": {
            "mode": "palette-classic"
          },
          "customAxisLabel": "Decisions/min",
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "go" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "no_go" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "review" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Decision Latency (ms) — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "quantile(0.50, rate(quantumarb_decision_latency_ms_sum[5m]) / rate(quantumarb_decision_latency_ms_count[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "quantile(0.95, rate(quantumarb_decision_latency_ms_sum[5m]) / rate(quantumarb_decision_latency_ms_count[5m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "quantile(0.99, rate(quantumarb_decision_latency_ms_sum[5m]) / rate(quantumarb_decision_latency_ms_count[5m]))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "ms"
        }
      }
    },
    {
      "title": "Calibration Error by Signal Type",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "quantumarb_calibration_error", "legendFormat": "{{signal_type}}", "refId": "A", "interval": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1 },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.15 }
            ]
          },
          "customAxisLabel": "Calibration Error"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "title": "Execution & Trades",
      "type": "row"
    },
    {
      "title": "Total PnL by Venue & Symbol (USD)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "quantumarb_pnl_total_usd", "legendFormat": "{{venue}} / {{symbol}}", "refId": "A", "interval": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "currencyUSD",
          "decimals": 2
        }
      }
    },
    {
      "title": "Trade Execution Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum(rate(quantumarb_trades_executed_total[1m])) by (venue, symbol, side)", "legendFormat": "{{venue}} {{symbol}} {{side}}", "refId": "A", "interval": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 15 },
          "unit": "short"
        }
      }
    },
    {
      "title": "Execution Latency (ms) by Venue & Leg — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 26 },
      "id": 8,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "quantile(0.50, rate(quantumarb_execution_latency_ms_sum[5m]) / rate(quantumarb_execution_latency_ms_count[5m])) by (venue, leg)", "legendFormat": "p50 {{venue}} {{leg}}", "refId": "A" },
        { "expr": "quantile(0.95, rate(quantumarb_execution_latency_ms_sum[5m]) / rate(quantumarb_execution_latency_ms_count[5m])) by (venue, leg)", "legendFormat": "p95 {{venue}} {{leg}}", "refId": "B" },
        { "expr": "quantile(0.99, rate(quantumarb_execution_latency_ms_sum[5m]) / rate(quantumarb_execution_latency_ms_count[5m])) by (venue, leg)", "legendFormat": "p99 {{venue}} {{leg}}", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1 },
          "unit": "ms"
        }
      }
    },
    {
      "title": "Spread Distribution (bps) by Arb Type",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 26 },
      "id": 9,
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "quantile(0.95, rate(quantumarb_spread_bps_sum[5m]) / rate(quantumarb_spread_bps_count[5m])) by (arb_type)", "legendFormat": "{{arb_type}} p95", "refId": "A", "interval": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short",
          "customAxisLabel": "bps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 10,
      "title": "Risk & Safety",
      "type": "row"
    },
    {
