# Media Grid Configuration
# Copy to .env and customize

# Environment
MEDIA_ENVIRONMENT=development  # development | staging | production

# Agents
MEDIA_ENABLE_TREND_HARVESTER=true
MEDIA_ENABLE_SCRIPT_AGENT=true
MEDIA_ENABLE_ASSET_AGENT=true
MEDIA_ENABLE_EDIT_PACKAGING=true
MEDIA_ENABLE_PUBLISHER=true
MEDIA_ENABLE_ANALYTICS=true
MEDIA_ENABLE_LANDING_PAGE=true
MEDIA_ENABLE_OFFER_INTELLIGENCE=true
MEDIA_ENABLE_SIMP_NEWS=true

# Content Generation
MEDIA_DEFAULT_GENERATION_TOOL=higgsfield  # higgsfield | minimax | elevenlabs | openai
MEDIA_MAX_CONTENT_PER_DAY=20
MEDIA_QUALITY_MODE=balanced  # fast | balanced | premium

# Publishing
MEDIA_ENABLE_TIKTOK=true
MEDIA_ENABLE_YOUTUBE_SHORTS=true
MEDIA_ENABLE_INSTAGRAM_REELS=true
MEDIA_ENABLE_X=false

# Monetization
MEDIA_MIN_AFFILIATE_COMMISSION=20.0
MEDIA_DEFAULT_AFFILIATE_NETWORK=amazon

# Budget
MEDIA_DAILY_BUDGET=50.0
MEDIA_MAX_COST_PER_CONTENT=5.0
MEDIA_BUDGET_ALERT_THRESHOLD=0.8

# Performance
MEDIA_RATE_LIMIT_CALLS_PER_MINUTE=10

# SIMP Integration
MEDIA_SIMP_BROKER_URL=http://127.0.0.1:5555
MEDIA_SIMP_API_KEY=
