{
  "exchange_config": {
    "api_key_name": "${COINBASE_API_KEY_NAME}",
    "api_secret": "${COINBASE_API_PRIVATE_KEY}",
    "timeout_seconds": 30,
    "key_file": "config/coinbase_cdp_key.json"
  },
  "symbols": [
    "BTC-USD",
    "ETH-USD",
    "SOL-USD"
  ],
  "position_sizing": {
    "min_notional": 1.0,
    "max_notional": 10.0
  },
  "risk_management": {
    "circuit_breakers": {
      "max_hourly_trades": 30,
      "max_daily_trades": 100,
      "max_consecutive_losses": 4,
      "cool_down_minutes": 15
    }
  },
  "trading_hours": {
    "days_active": [
      "monday",
      "tuesday",
      "wednesday",
      "thursday",
      "friday",
      "saturday",
      "sunday"
    ],
    "start_time_utc": "00:00",
    "end_time_utc": "23:59"
  },
  "execution": {
    "dry_run": false
  },
  "environment": "production",
  "version": "1.0.0"
}